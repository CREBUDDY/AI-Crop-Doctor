# ─── Backend ──────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crop_doctor

# Firebase (Service Account JSON path for backend)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# AI Confidence Threshold (0.0 - 1.0)
AI_CONFIDENCE_THRESHOLD=0.80

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=AI Crop Doctor
VERSION=1.0.0

# ─── Frontend (.env.local) ────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_API_V1_PREFIX=/api/v1

# Firebase (Frontend SDK — these are safe to expose)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_VAPID_KEY=your_fcm_vapid_key_for_web_push
